# ==================== APPLICATION ====================
NODE_ENV=development
APP_NAME=LabGrandisol
APP_VERSION=2.0.0
APP_PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5174

# ==================== DATABASE ====================
# SQLite (Development - Default)
DATABASE_TYPE=sqlite
SQLITE_PATH=./data/labgrandisol.db

# PostgreSQL (Production - Uncomment to use)
# DATABASE_TYPE=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5433
# POSTGRES_USER=labgrandisol
# POSTGRES_PASSWORD=mudar_em_producao_senha_super_secreta_12345
# POSTGRES_DB=labgrandisol

# MySQL (Alternative - Uncomment to use)
# DATABASE_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=password
# MYSQL_DB=labgrandisol

# ==================== AUTHENTICATION ====================
JWT_SECRET=gerar_chave_aleatoria_long_45_caracteres_s3cr3t0
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_this_12345

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ==================== EMAIL/NOTIFICATIONS ====================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@example.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=LabGrandisol <noreply@example.com>
MAIL_DEBUG=false

# ==================== SECURITY ====================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://wiki.local
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret_key_change_this

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# ==================== AWS (Optional) ====================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ==================== SENTRY (Error Tracking) ====================
SENTRY_DSN=

# ==================== API DOCUMENTATION ====================
API_DOC_ENABLED=true
API_DOC_PATH=/api-docs
SWAGGER_ENABLED=true

# ==================== FEATURE FLAGS ====================
FEATURE_ADVANCED_LIBRARY=true
FEATURE_SOCIAL=true
FEATURE_REPORTS=true
FEATURE_ADMIN_PANEL=true
FEATURE_SAAS=true
FEATURE_NOTIFICATIONS=true

# ==================== TESTING ====================
TEST_DATABASE_URL=sqlite:///:memory:
TEST_JWT_SECRET=test_secret_key_only_for_testing

